# =============================================================================
# Frontend Next.js + NextAuth
# Desenvolvimento local: copie para .env.local →  cp .env.example .env.local
# Docker (compose nesta pasta): pode usar ficheiro .env com as mesmas chaves.
# =============================================================================

# URL pública onde o browser abre o Next (NextAuth) — em produção: https://faturamentocedulapromotora.com.br
NEXTAUTH_URL=http://localhost:3000

# Obrigatório: segredo para assinar JWT/cookies do NextAuth (mín. ~32 caracteres em produção)
NEXTAUTH_SECRET=outro_segredo_longo_obrigatorio

# URL base da API Django (tem de terminar em /integration). Porta do Gunicorn, NÃO a 3000 do Next.
# - Next na máquina + API no host ou Docker publicado em 8005:
NEXT_INTEGRATION_URL=http://127.0.0.1:8005/integration
# - Next dentro do Docker (compose desta pasta):
# NEXT_INTEGRATION_URL=http://host.docker.internal:8005/integration

# URL pública do site (HTTPS) — usada no build Docker (NEXT_PUBLIC_*)
NEXT_PUBLIC_APP_URL=https://faturamentocedulapromotora.com.br

# E-mail do proprietário (rodapé do login, mailto)
NEXT_PUBLIC_OWNER_EMAIL=cedulapromotora@gmail.com

# Onde o Next fica mapeado no host (por defeito no compose: 127.0.0.1:3000).
# FRONTEND_PUBLISH=0.0.0.0:3000

# --- Deploy VPS (Nginx + HTTPS) ---
# Guia: deploy/hostinger/README.md
# Domínio + Let's Encrypt: nginx/vhost-faturamentocedulapromotora.com.br.conf
